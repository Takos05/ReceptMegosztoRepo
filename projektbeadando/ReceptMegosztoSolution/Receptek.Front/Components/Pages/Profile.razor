@page "/profile"
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using FrontModels = global::Receptek.Front.MODEL
@using SharedModels = ReceptekLibrary.MODELL
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@rendermode InteractiveServer

<PageTitle>Profil</PageTitle>

@if (isLoading)
{
    <p>Betöltés...</p>
}
else if (!isAuthenticated)
{
    <div class="row g-4 profile-auth-layout">
        <div class="col-12 col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h4 class="mb-3">Bejelentkezés</h4>

                    @if (showLoginError)
                    {
                        <p class="text-danger">Sikertelen bejelentkezés.</p>
                    }

                    <form method="post" action="/auth/login-form">
                        <input type="hidden" name="returnUrl" value="/profile" />

                        <div class="mb-3">
                            <label for="username" class="form-label">Felhasználónév</label>
                            <input id="username" name="Username" class="form-control" value="@loginModel.Username" />
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Jelszó</label>
                            <input id="password" name="Password" type="password" class="form-control" value="@loginModel.Password" />
                        </div>

                        <button type="submit" class="btn btn-primary">Belépés</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h4 class="mb-3">Regisztráció</h4>

                    <EditForm Model="registerModel" OnValidSubmit="RegisterUser">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Felhasználónév</label>
                            <InputText @bind-Value="registerModel.Username" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText @bind-Value="registerModel.Email" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Jelszó</label>
                            <InputText @bind-Value="registerModel.Password" type="password" class="form-control" />
                        </div>

                        <button type="submit" class="btn btn-success" disabled="@isRegisterBusy">
                            @(isRegisterBusy ? "Folyamatban..." : "Regisztráció")
                        </button>
                    </EditForm>

                    @if (!string.IsNullOrWhiteSpace(registerMessage))
                    {
                        <p class="mt-3 mb-0">@registerMessage</p>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="card p-3 p-md-4 profile-card">
        <h4>@currentUserName</h4>

        <p><strong>Email:</strong> @currentUserEmail</p>

        <hr />

        <form method="post" action="/auth/logout-form">
            <input type="hidden" name="returnUrl" value="/profile" />
            <button type="submit" class="btn btn-outline-danger">Kijelentkezés</button>
        </form>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-3">
            <h5 class="mb-0">Saját receptjeim</h5>
            <a href="/recipecreate" class="btn btn-primary">
                Új recept készítése
            </a>
        </div>

        @if (!string.IsNullOrWhiteSpace(recipesMessage))
        {
            <p>@recipesMessage</p>
        }

        @if (userRecipes.Count == 0)
        {
            <p>Még nincs feltöltött recepted.</p>
        }
        else
        {
            <div class="list-group">
                @foreach (var recipe in userRecipes)
                {
                    <div class="list-group-item">
                        <div class="d-flex flex-column flex-sm-row gap-2">
                            <p class="mb-1"><strong>@recipe.title</strong></p>
                            <a class="btn btn-outline-primary btn-sm"
                               href="@($"/receptek/{recipe.recipe_id}")">
                                Megnyitás
                            </a>

                            <a class="btn btn-warning btn-sm"
                               href="@($"/recipeedit/{recipe.recipe_id}")">
                                Szerkesztés
                            </a>

                            <button class="btn btn-outline-danger btn-sm"
                                    @onclick="() => DeleteRecipe(recipe.recipe_id)">
                                Törlés
                            </button>
                        </div>
                    </div>
                }
            </div>
        }

        <h5 class="mt-4">Alapértelmezett tagek</h5>

        @if (!string.IsNullOrWhiteSpace(tagsMessage))
        {
            <p>@tagsMessage</p>
        }

        <button class="btn btn-primary w-100 w-md-auto" @onclick="SaveUserDefaultTags" disabled="@isSavingTags">
            @(isSavingTags ? "Mentés..." : "Default tagek mentése")
        </button>

        @if (tagsByCategory.Count == 0)
        {
            <p>Nincsenek elérhető tagek.</p>
        }
        else
        {
            @foreach (var category in tagsByCategory.OrderBy(c => c.Key))
            {
                var isCollapsed = IsCategoryCollapsed(category.Key);

                <div class="mb-3 border rounded">
                    <button type="button"
                            class="btn w-100 text-start fw-bold"
                            @onclick="() => ToggleCategory(category.Key)">
                        @(isCollapsed ? "►" : "▼") @category.Key
                    </button>

                    @if (!isCollapsed)
                    {
                        <div class="p-3 pt-2">
                            @foreach (var tagName in category.Value.OrderBy(t => t))
                            {
                                if (!tagNameToId.TryGetValue(tagName, out var tagId))
                                {
                                    continue;
                                }

                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="tag_@tagId"
                                           checked="@BindTag(tagId)"
                                           @onchange="(ChangeEventArgs e) => BindTag(tagId, Convert.ToBoolean(e.Value))" />
                                    <label class="form-check-label" for="tag_@tagId">
                                        @tagName
                                    </label>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }

        <hr />
    </div>
}

@code {
    private FrontModels.LoginRequest loginModel = new();
    private FrontModels.RegisterModel registerModel = new();

    private bool isLoading = true;
    private bool isAuthenticated = false;
    private bool showLoginError = false;

    private bool isRegisterBusy = false;
    private bool isSavingTags = false;

    private string registerMessage = string.Empty;
    private string tagsMessage = string.Empty;

    private string currentUserName = string.Empty;
    private string currentUserEmail = string.Empty;
    private int currentUserId;

    private List<SharedModels.Tags> allTags = new();
    private Dictionary<string, string[]> tagsByCategory = new();
    private Dictionary<string, int> tagNameToId = new();

    private HashSet<int> selectedTagIds = new();

    private List<SharedModels.Recipes> userRecipes = new();
    private string recipesMessage = string.Empty;
    private bool isDeletingRecipe = false;

    private HashSet<string> collapsedCategories = new();

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (uri.Query.Contains("error=1"))
        {
            showLoginError = true;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            isAuthenticated = true;

            currentUserName =
                user.FindFirst(ClaimTypes.Name)?.Value
                ?? user.Identity?.Name
                ?? string.Empty;

            currentUserEmail =
                user.FindFirst(ClaimTypes.Email)?.Value
                ?? string.Empty;

            var idClaim =
                user.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? user.FindFirst("sub")?.Value;

            if (int.TryParse(idClaim, out var parsedUserId))
            {
                currentUserId = parsedUserId;
            }

            await LoadCurrentUserData();
            await LoadTags();
            await LoadUserRecipes();
        }

        isLoading = false;
    }

    private async Task LoadUserRecipes()
    {
        try
        {
            if (currentUserId <= 0)
            {
                userRecipes = new List<SharedModels.Recipes>();
                return;
            }

            userRecipes = await Http.GetFromJsonAsync<List<SharedModels.Recipes>>(
                $"api/recipe/byUser/{currentUserId}")
                ?? new List<SharedModels.Recipes>();
        }
        catch (Exception ex)
        {
            recipesMessage = $"A receptek betöltése sikertelen: {ex.Message}";
        }
    }

    private async Task DeleteRecipe(int recipeId)
    {
        if (isDeletingRecipe)
            return;

        isDeletingRecipe = true;
        recipesMessage = string.Empty;

        try
        {
            var response = await Http.DeleteAsync($"api/recipe/{recipeId}");

            if (response.IsSuccessStatusCode)
            {
                userRecipes = userRecipes
                    .Where(r => r.recipe_id != recipeId)
                    .ToList();

                recipesMessage = "A recept törlése sikeres.";
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                recipesMessage = string.IsNullOrWhiteSpace(errorText)
                    ? "A recept törlése sikertelen."
                    : errorText;
            }
        }
        catch (Exception ex)
        {
            recipesMessage = $"Törlési hiba: {ex.Message}";
        }
        finally
        {
            isDeletingRecipe = false;
        }
    }

    private async Task LoadCurrentUserData()
    {
        try
        {
            var users = await Http.GetFromJsonAsync<List<SharedModels.Users>>("api/user");

            if (users is null)
                return;

            SharedModels.Users? currentUser = null;

            if (currentUserId > 0)
            {
                currentUser = users.FirstOrDefault(u => u.user_id == currentUserId);
            }

            currentUser ??= users.FirstOrDefault(u => u.username == currentUserName);

            if (currentUser is not null)
            {
                currentUserEmail = currentUser.email;
                currentUserName = currentUser.username;
                currentUserId = currentUser.user_id;
            }
        }
        catch (Exception ex)
        {
            tagsMessage = $"A felhasználó adatainak betöltése sikertelen: {ex.Message}";
        }
    }

    private async Task LoadTags()
    {
        try
        {
            allTags = await Http.GetFromJsonAsync<List<SharedModels.Tags>>("api/tags/all")
                ?? new List<SharedModels.Tags>();

            tagsByCategory = await Http.GetFromJsonAsync<Dictionary<string, string[]>>("api/tags/byCategories")
                ?? new Dictionary<string, string[]>();

            tagNameToId = allTags
                .GroupBy(t => t.tag_name)
                .ToDictionary(g => g.Key, g => g.First().tag_id);

            if (currentUserId > 0)
            {
                var userDefaultTags =
                    await Http.GetFromJsonAsync<List<SharedModels.Tags>>($"api/tags/UserDefaults?userId={currentUserId}")
                    ?? new List<SharedModels.Tags>();

                selectedTagIds = userDefaultTags
                    .Select(t => t.tag_id)
                    .ToHashSet();
            }
        }
        catch (Exception ex)
        {
            tagsMessage = $"A tagek betöltése sikertelen: {ex.Message}";
        }
    }

    private bool BindTag(int tagId)
    {
        return selectedTagIds.Contains(tagId);
    }

    private void BindTag(int tagId, bool value)
    {
        if (value)
        {
            selectedTagIds.Add(tagId);
        }
        else
        {
            selectedTagIds.Remove(tagId);
        }
    }

    private void ToggleCategory(string categoryName)
    {
        if (collapsedCategories.Contains(categoryName))
        {
            collapsedCategories.Remove(categoryName);
        }
        else
        {
            collapsedCategories.Add(categoryName);
        }
    }

    private bool IsCategoryCollapsed(string categoryName)
    {
        return collapsedCategories.Contains(categoryName);
    }

    private async Task RegisterUser()
    {
        if (isRegisterBusy)
            return;

        isRegisterBusy = true;
        registerMessage = string.Empty;

        try
        {
            var payload = new
            {
                username = registerModel.Username,
                email = registerModel.Email,
                password = registerModel.Password
            };

            var response = await Http.PostAsJsonAsync("api/auth/register", payload);

            if (response.IsSuccessStatusCode)
            {
                registerModel = new FrontModels.RegisterModel();
                registerMessage = "Sikeres regisztráció. Most már be tudsz jelentkezni.";
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                registerMessage = string.IsNullOrWhiteSpace(err)
                    ? $"Hiba történt. Státuszkód: {(int)response.StatusCode}"
                    : err;
            }
        }
        catch (Exception ex)
        {
            registerMessage = $"Kivétel történt: {ex.Message}";
        }
        finally
        {
            isRegisterBusy = false;
        }
    }

    private async Task SaveUserDefaultTags()
    {
        if (currentUserId <= 0)
        {
            tagsMessage = "A felhasználó azonosítója nem található.";
            return;
        }

        isSavingTags = true;
        tagsMessage = string.Empty;

        try
        {
            var request = new SaveUserDefaultTagsRequest
                {
                    UserId = currentUserId,
                    TagIds = selectedTagIds.ToList()
                };

            var response = await Http.PostAsJsonAsync("api/tags/UserDefaults", request);

            if (response.IsSuccessStatusCode)
            {
                tagsMessage = "A default tagek mentése sikeres.";
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                tagsMessage = string.IsNullOrWhiteSpace(err)
                    ? "A default tagek mentése sikertelen."
                    : err;
            }
        }
        catch (Exception ex)
        {
            tagsMessage = $"Mentési hiba: {ex.Message}";
        }
        finally
        {
            isSavingTags = false;
        }
    }

    private class SaveUserDefaultTagsRequest
    {
        [Required]
        public int UserId { get; set; }

        public List<int> TagIds { get; set; } = new();
    }
}