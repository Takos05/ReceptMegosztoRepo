@page "/receptek"
@inject HttpClient Http
@rendermode InteractiveServer
@using ReceptekLibrary.MODELL
@using System.Net.Http.Json
@using System.Linq


<div class="recipes-page">
<input class="form-control mb-3"
       placeholder="Keresés recept név alapján..."
       @bind="searchText"
       @oninput="SearchChanged" />

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (FilteredRecipes?.Count > 0)
{
    <div class="recipes-grid">
    @foreach (var recept in FilteredRecipes)
    {
        <div class="card recipe-card">
            <a href="@($"/receptek/{recept.recipe_id}")" class="text-decoration-none text-dark">
                <div class="card-body">
                    <h5 class="card-title">@recept.title</h5>
                    <p>@felhasznalok.Find(x => x.user_id == recept.user_id).username</p>
                    <p class="card-text">@recept.description</p>
                    <p>Értékelés: ⭐ @GetRating(recept.recipe_id)</p>
                </div>
            </a>
        </div>
    }
    </div>
}
</div>
else
{
    <p>No recipes found.</p>
}

@code {

    List<Users> felhasznalok = new();
    List<Recipes> serverRecipes = new();
    List<Recipes> FilteredRecipes = new();
    Dictionary<int, double> ratings = new();

    string searchText = "";
    string? errorMessage;

    void SearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";
        FilterRecipes();
    }

    void FilterRecipes()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            FilteredRecipes = serverRecipes;
        }
        else
        {
            FilteredRecipes = serverRecipes
                .Where(r => r.title.ToLower().Contains(searchText.ToLower()))
                .ToList();
        }
    }

    double GetRating(int recipeId)
    {
        if (ratings.ContainsKey(recipeId))
            return Math.Round(ratings[recipeId], 1);

        return 0;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("/api/Recipe");
            if (response.IsSuccessStatusCode)
            {
                serverRecipes = await response.Content.ReadFromJsonAsync<List<Recipes>>() ?? new List<Recipes>();
                felhasznalok = await Http.GetFromJsonAsync<List<Users>>("/api/User") ?? new List<Users>();
                FilteredRecipes = serverRecipes;

                foreach (var recipe in serverRecipes)
                {
                    try
                    {
                        var avg = await Http.GetFromJsonAsync<double>(
                            $"/api/Rating/averageByRecipe?recipeId={recipe.recipe_id}");

                        ratings[recipe.recipe_id] = avg;
                    }
                    catch
                    {
                        ratings[recipe.recipe_id] = 0;
                    }
                }
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = $"API error {(int)response.StatusCode} {response.ReasonPhrase}: {body}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Request failed: {ex.Message}";
        }
    }
}
