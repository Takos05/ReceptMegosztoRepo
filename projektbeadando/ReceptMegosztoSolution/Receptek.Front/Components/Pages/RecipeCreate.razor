@page "/recipecreate"
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using SharedModels = ReceptekLibrary.MODELL
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@rendermode InteractiveServer

<PageTitle>Új recept</PageTitle>



@if (isLoading)
{
    <p>Betöltés...</p>
}
else if (!isAuthenticated)
{
    <div class="alert alert-warning">
        Új recept létrehozásához be kell jelentkezned.
    </div>

    <a class="btn btn-primary" href="/profile">Bejelentkezés</a>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <EditForm Model="model" OnValidSubmit="CreateRecipe">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Cím</label>
                    <InputText @bind-Value="model.Title" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Leírás</label>
                    <InputTextArea @bind-Value="model.Description" class="form-control" rows="6" />
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Előkészítési idő (perc)</label>
                        <InputNumber @bind-Value="model.PrepTimeMin" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Főzési / sütési idő (perc)</label>
                        <InputNumber @bind-Value="model.CookTimeMin" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Adag</label>
                        <InputNumber @bind-Value="model.Servings" class="form-control" />
                    </div>
                </div>

                <hr />

                <h5>Tagek</h5>

                @if (!string.IsNullOrWhiteSpace(tagsMessage))
                {
                    <p>@tagsMessage</p>
                }

                @if (tagsByCategory.Count == 0)
                {
                    <p>Nincsenek elérhető tagek.</p>
                }
                else
                {
                    @foreach (var category in tagsByCategory.OrderBy(c => c.Key))
                    {
                        var isCollapsed = IsCategoryCollapsed(category.Key);

                        <div class="mb-3 border rounded">
                            <button type="button"
                                    class="btn w-100 text-start fw-bold"
                                    @onclick="() => ToggleCategory(category.Key)">
                                @(isCollapsed ? "►" : "▼") @category.Key
                            </button>

                            @if (!isCollapsed)
                            {
                                <div class="p-3 pt-2">
                                    @foreach (var tagName in category.Value.OrderBy(t => t))
                                    {
                                        if (!tagNameToId.ContainsKey(tagName))
                                        {
                                            continue;
                                        }

                                        var tagId = tagNameToId[tagName];

                                        <div class="form-check">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   id="tag_@tagId"
                                                   checked="@selectedTagIds.Contains(tagId)"
                                                   @onclick="() => ToggleTag(tagId)" />
                                            <label class="form-check-label" for="tag_@tagId">
                                                @tagName
                                            </label>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert alert-info mt-3">@message</div>
                }

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-success" disabled="@isSaving">
                        @(isSaving ? "Mentés..." : "Recept létrehozása")
                    </button>

                    <a class="btn btn-secondary" href="/profile">Mégse</a>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private RecipeCreateModel model = new();

    private bool isLoading = true;
    private bool isAuthenticated = false;
    private bool isSaving = false;

    private int currentUserId;
    private string message = string.Empty;
    private string tagsMessage = string.Empty;

    private List<SharedModels.Tags> allTags = new();
    private Dictionary<string, string[]> tagsByCategory = new();
    private Dictionary<string, int> tagNameToId = new();
    private HashSet<int> selectedTagIds = new();

    private HashSet<string> collapsedCategories = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            isAuthenticated = true;

            var idClaim =
                user.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? user.FindFirst("sub")?.Value;

            if (int.TryParse(idClaim, out var parsedUserId))
            {
                currentUserId = parsedUserId;
            }

            await LoadTags();
        }

        isLoading = false;
    }

    private async Task LoadTags()
    {
        try
        {
            allTags = await Http.GetFromJsonAsync<List<SharedModels.Tags>>("api/tags/all")
                      ?? new List<SharedModels.Tags>();

            tagsByCategory = await Http.GetFromJsonAsync<Dictionary<string, string[]>>("api/tags/byCategories")
                             ?? new Dictionary<string, string[]>();

            tagNameToId = allTags
                .GroupBy(t => t.tag_name)
                .ToDictionary(g => g.Key, g => g.First().tag_id);
        }
        catch (Exception ex)
        {
            tagsMessage = $"A tagek betöltése sikertelen: {ex.Message}";
        }
    }

    private void ToggleTag(int tagId)
    {
        if (selectedTagIds.Contains(tagId))
        {
            selectedTagIds.Remove(tagId);
        }
        else
        {
            selectedTagIds.Add(tagId);
        }
    }
   

    private async Task CreateRecipe()
    {
        if (isSaving)
            return;

        if (currentUserId <= 0)
        {
            message = "A felhasználó azonosítója nem található.";
            return;
        }

        isSaving = true;
        message = string.Empty;

        try
        {
            var request = new CreateRecipeRequest
                {
                    user_id = currentUserId,
                    title = model.Title,
                    description = model.Description,
                    prep_time_min = model.PrepTimeMin,
                    cook_time_min = model.CookTimeMin,
                    servings = model.Servings,
                    tag_ids = selectedTagIds.ToList()
                };

            var response = await Http.PostAsJsonAsync("api/recipe/withTags", request);

            if (response.IsSuccessStatusCode)
            {
                var createdRecipe = await response.Content.ReadFromJsonAsync<SharedModels.Recipes>();

                if (createdRecipe is not null)
                {
                    Navigation.NavigateTo($"/receptek/{createdRecipe.recipe_id}");
                    return;
                }

                Navigation.NavigateTo("/profile", forceLoad: true);
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                message = string.IsNullOrWhiteSpace(errorText)
                    ? "A recept létrehozása sikertelen."
                    : errorText;
            }
        }
        catch (Exception ex)
        {
            message = $"Hiba történt: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private class RecipeCreateModel
    {
        [Required(ErrorMessage = "A cím megadása kötelező.")]
        public string Title { get; set; } = string.Empty;

        [Required(ErrorMessage = "A leírás megadása kötelező.")]
        public string Description { get; set; } = string.Empty;

        [Range(0, 10000, ErrorMessage = "Az előkészítési idő nem lehet negatív.")]
        public int PrepTimeMin { get; set; }

        [Range(0, 10000, ErrorMessage = "A főzési idő nem lehet negatív.")]
        public int CookTimeMin { get; set; }

        [Range(1, 1000, ErrorMessage = "Legalább 1 adagot meg kell adni.")]
        public int Servings { get; set; } = 1;
    }

    private class CreateRecipeRequest
    {
        public int user_id { get; set; }
        public string title { get; set; } = string.Empty;
        public string description { get; set; } = string.Empty;
        public int prep_time_min { get; set; }
        public int cook_time_min { get; set; }
        public int servings { get; set; }
        public List<int> tag_ids { get; set; } = new();
    }

    private void ToggleCategory(string categoryName)
    {
        if (collapsedCategories.Contains(categoryName))
        {
            collapsedCategories.Remove(categoryName);
        }
        else
        {
            collapsedCategories.Add(categoryName);
        }
    }

    private bool IsCategoryCollapsed(string categoryName)
    {
        return collapsedCategories.Contains(categoryName);
    }
}