@page "/receptek/{id:int}"
@inject HttpClient Http
@using ReceptekLibrary.MODELL
@using System.Net
@using System.Net.Http.Json
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@using System.Security.Claims

<h3>Recept részletei</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (recipe == null)
{
    <p>Betöltés...</p>
}
else
{
    <!-- Recept -->
    <div class="card mb-4">
        <div class="card-body">
            <h4 class="card-title">@recipe.title</h4>

            <p style="white-space: pre-line">@recipe.description</p>

            <ul class="mb-0">
                <li>Előkészítés: @recipe.prep_time_min perc</li>
                <li>Főzés / sütés: @recipe.cook_time_min perc</li>
                <li>Adagok: @recipe.servings</li>
                <li>Létrehozva: @recipe.created_at.ToString("yyyy-MM-dd")</li>
            </ul>
        </div>
    </div>

    <!-- Értékelés -->
    <div class="card mb-4">
        <div class="card-body">
            <h4 class="card-title">Értékelés</h4>

            @if (!string.IsNullOrEmpty(ratingErrorMessage))
            {
                <div class="alert alert-warning">@ratingErrorMessage</div>
            }
            else
            {
                <div class="d-flex align-items-center gap-3">
                    <div style="font-size: 2rem; line-height: 1;">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= roundedStars)
                            {
                                <span style="color: gold;">★</span>
                            }
                            else
                            {
                                <span style="color: lightgray;">☆</span>
                            }
                        }
                    </div>

                    <div>
                        <strong>@averageRating.ToString("0.0") / 5</strong>
                    </div>
                </div>
            }
        </div>
        @if (isLoggedIn)
        {
            <div class="border rounded p-3 mt-3">
                <div class="mb-2">
                    <strong>Saját értékelés:</strong>
                </div>

                <!-- Kattintható csillagok -->
                <div class="mb-3" style="font-size: 2rem;">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var starValue = i;
                        <button type="button"
                                class="btn btn-link p-0 me-1 text-decoration-none"
                                style="font-size: 2rem; color: @(starValue <= selectedRating ? "gold" : "lightgray");"
                                @onclick="() => SelectRating(starValue)">
                            @(starValue <= selectedRating ? "★" : "☆")
                        </button>
                    }
                </div>

                <!-- Pillanatnyilagi értékelés -->
                @if (currentUserRating != null)
                {
                    <p class="text-muted">
                        Jelenlegi értékelésed: <strong>@currentUserRating.ratings_value / 5</strong>
                    </p>
                }

                <!-- Mentés -->
                <button class="btn btn-primary"
                        @onclick="SaveRating"
                        disabled="@ratingSubmitting">
                    @(currentUserRating == null ? "Értékelés mentése" : "Értékelés módosítása")
                </button>

                <!-- Siker -->
                @if (!string.IsNullOrWhiteSpace(ratingSuccessMessage))
                {
                    <div class="alert alert-success mt-2">
                        @ratingSuccessMessage
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted">Értékeléshez jelentkezz be.</p>
        }
    </div>

    <!-- Kommentek -->
    @if (isLoggedIn)
    {
        <div class="mt-4">
            <h5>Írj kommentet</h5>

            <textarea class="form-control"
                      @bind="ujKomment"
                      placeholder="Írd ide a véleményed..."
                      rows="4"></textarea>

            <button class="btn btn-primary mt-2" @onclick="KommentKuldes">
                Küldés
            </button>
        </div>
    }
    else
    {
        <p class="text-muted mt-3">
            Komment írásához jelentkezz be.
        </p>
    }

    <div class="card mb-4">
        <div class="card-body">
            <h4 class="card-title">Kommentek</h4>

            @if (commentsLoading)
            {
                <p>Kommentek betöltése...</p>
            }
            else if (!string.IsNullOrEmpty(commentsErrorMessage))
            {
                <div class="alert alert-warning">@commentsErrorMessage</div>
            }
            else if (comments == null || comments.Count == 0)
            {
                <p>Még nincs komment ehhez a recepthez.</p>
            }
            else
            {
                <div class="list-group">
                    @foreach (var comment in comments.OrderByDescending(c => c.created_at))
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <strong>@GetUserName(comment.user_id)</strong>
                                    <small>@comment.created_at.ToString("yyyy-MM-dd HH:mm")</small>
                                </div>

                                @if (CanDeleteComment(comment))
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => DeleteComment(comment.comment_id)">
                                        Törlés
                                    </button>
                                }
                            </div>
                            <div class="mt-2">
                                @comment.comment_text
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <a class="btn btn-secondary" href="/receptek">Vissza a listához</a>
}

@code {
    
    private string ujKomment = string.Empty;

    
    [Parameter]
    public int id { get; set; }

    private Recipes? recipe;

    private double averageRating = 0;
    private int roundedStars = 0;

    private List<Comments> comments = new();
    private List<Users> users = new();

    private string? errorMessage;
    private string? ratingErrorMessage;
    private string? commentsErrorMessage;

    private bool commentsLoading = true;

    private ClaimsPrincipal? currentUser;
    private bool isLoggedIn;
    private string? currentUserName;
    private int? currentUserId;
    private bool isAdmin;

    private Ratings? currentUserRating;
    private double selectedRating = 0;

    private bool ratingSubmitting = false;
    private string? ratingSuccessMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUser();
        await LoadAllData();
    }

    private async Task LoadAllData()
    {
        try
        {
            await LoadRecipe();

            if (recipe != null)
            {
                await LoadUsers();
                await LoadRating();
                await LoadComments(); 
                await LoadCurrentUserRating();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Hiba történt: {ex.Message}";
        }
    }

    private async Task LoadRecipe()
    {
        var recipeResponse = await Http.GetAsync($"/api/Recipe/Recipes/{id}");

        if (recipeResponse.IsSuccessStatusCode)
        {
            recipe = await recipeResponse.Content.ReadFromJsonAsync<Recipes>();
        }
        else if (recipeResponse.StatusCode == HttpStatusCode.NotFound)
        {
            errorMessage = "A recept nem található.";
        }
        else
        {
            var body = await recipeResponse.Content.ReadAsStringAsync();
            errorMessage = $"Recept betöltési hiba {(int)recipeResponse.StatusCode} {recipeResponse.ReasonPhrase}: {body}";
        }
    }

    private async Task LoadUsers()
    {
        try
        {
            var usersResponse = await Http.GetAsync("/api/User");

            if (usersResponse.IsSuccessStatusCode)
            {
                users = await usersResponse.Content.ReadFromJsonAsync<List<Users>>() ?? new List<Users>();
            }
            else
            {
                users = new List<Users>();
            }
        }
        catch
        {
            users = new List<Users>();
        }

        if (isLoggedIn && currentUserId == null && !string.IsNullOrWhiteSpace(currentUserName))
        {
            var matchedUser = users.FirstOrDefault(u => u.username == currentUserName);

            if (matchedUser != null)
            {
                currentUserId = matchedUser.user_id;
            }
        }
    }

    private async Task LoadRating()
    {
        try
        {
            var ratingResponse = await Http.GetAsync($"/api/Rating/averageByRecipe?recipeId={id}");

            if (ratingResponse.IsSuccessStatusCode)
            {
                averageRating = await ratingResponse.Content.ReadFromJsonAsync<double>();
                roundedStars = (int)Math.Round(averageRating, MidpointRounding.AwayFromZero);

                if (roundedStars < 0) roundedStars = 0;
                if (roundedStars > 5) roundedStars = 5;
            }
            else
            {
                var body = await ratingResponse.Content.ReadAsStringAsync();
                ratingErrorMessage = $"Értékelés betöltési hiba {(int)ratingResponse.StatusCode} {ratingResponse.ReasonPhrase}: {body}";
            }
        }
        catch (Exception ex)
        {
            ratingErrorMessage = $"Értékelés betöltése sikertelen: {ex.Message}";
        }
    }

    private async Task LoadComments()
    {
        commentsLoading = true;

        try
        {
            var commentsResponse = await Http.GetAsync($"/api/Recipe/comments/{id}");

            if (commentsResponse.IsSuccessStatusCode)
            {
                comments = await commentsResponse.Content.ReadFromJsonAsync<List<Comments>>() ?? new List<Comments>();
            }
            else if (commentsResponse.StatusCode == HttpStatusCode.NotFound)
            {
                comments = new List<Comments>();
            }
            else
            {
                var body = await commentsResponse.Content.ReadAsStringAsync();
                commentsErrorMessage = $"Komment betöltési hiba {(int)commentsResponse.StatusCode} {commentsResponse.ReasonPhrase}: {body}";
            }
        }
        catch (Exception ex)
        {
            commentsErrorMessage = $"Kommentek betöltése sikertelen: {ex.Message}";
        }
        finally
        {
            commentsLoading = false;
        }
    }

    private string GetUserName(int? userId)
    {
        if (!userId.HasValue)
            return "Ismeretlen felhasználó";

        var user = users.FirstOrDefault(u => u.user_id == userId.Value);

        return user?.username ?? $"Felhasználó #{userId.Value}";
    }

    private async Task LoadCurrentUser()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUser = authState.User;

        isLoggedIn = currentUser.Identity?.IsAuthenticated ?? false;
        currentUserName = currentUser.Identity?.Name;

        var userIdClaim = currentUser.FindFirst(ClaimTypes.NameIdentifier)?.Value
                         ?? currentUser.FindFirst("sub")?.Value
                         ?? currentUser.FindFirst("userid")?.Value
                         ?? currentUser.FindFirst("user_id")?.Value;

        if (int.TryParse(userIdClaim, out var parsedUserId))
            currentUserId = parsedUserId;
        else
            currentUserId = null;

        isAdmin =
            currentUser.IsInRole("Admin") ||
            currentUser.Claims.Any(c =>
            (c.Type == ClaimTypes.Role || c.Type == "role" || c.Type == "roles") &&
            c.Value == "Admin");
    }
    private async Task KommentKuldes()
    {
        if (!isLoggedIn)
        {
            commentsErrorMessage = "Komment írásához jelentkezz be.";
            return;
        }

        if (string.IsNullOrWhiteSpace(ujKomment))
        {
            commentsErrorMessage = "A komment nem lehet üres.";
            return;
        }

        commentsErrorMessage = null;

        var uj = new Comments
            {
                recipe_id = id,
                user_id = currentUserId.Value,
                comment_text = ujKomment.Trim(),
                created_at = DateTime.Now,
            };

        var response = await Http.PostAsJsonAsync("/api/Comment", uj);

        if (response.IsSuccessStatusCode)
        {
            ujKomment = string.Empty;
            await LoadComments();
        }
        else
        {
            var body = await response.Content.ReadAsStringAsync();
            commentsErrorMessage = $"Komment küldési hiba {(int)response.StatusCode}: {body}";
        }
    }

    private bool CanDeleteComment(Comments comment)
    {
        if (!isLoggedIn)
            return false;

        if (isAdmin)
            return true;

        return currentUserId != null && comment.user_id == currentUserId.Value;
    }

    private async Task DeleteComment(int commentId)
    {
        if (!isLoggedIn)
        {
            commentsErrorMessage = "Komment törléséhez jelentkezz be.";
            return;
        }

        commentsErrorMessage = null;

        var response = await Http.DeleteAsync($"/api/Comment/{commentId}");

        if (response.IsSuccessStatusCode)
        {
            await LoadComments();
        }
        else if (response.StatusCode == HttpStatusCode.Forbidden)
        {
            commentsErrorMessage = "Nincs jogosultságod a komment törléséhez.";
        }
        else
        {
            var body = await response.Content.ReadAsStringAsync();
            commentsErrorMessage = $"Komment törlési hiba {(int)response.StatusCode}: {body}";
        }
    }

    private async Task LoadCurrentUserRating()
    {
        if (!isLoggedIn || currentUserId == null)
        {
            currentUserRating = null;
            selectedRating = 0;
            return;
        }

        var response = await Http.GetAsync($"/api/Rating/userByRecipe?recipeId={id}&userId={currentUserId.Value}");

        if (response.IsSuccessStatusCode)
        {
            currentUserRating = await response.Content.ReadFromJsonAsync<Ratings>();

            if (currentUserRating != null)
            {
                selectedRating = currentUserRating.ratings_value;
            }
        }
        else
        {
            currentUserRating = null;
            selectedRating = 0;
        }
    }

    private void SelectRating(int value)
    {
        selectedRating = value;
        ratingSuccessMessage = null;
    }

    private async Task SaveRating()
    {
        if (!isLoggedIn || currentUserId == null)
        {
            ratingErrorMessage = "Értékeléshez jelentkezz be.";
            return;
        }

        if (selectedRating < 1 || selectedRating > 5)
        {
            ratingErrorMessage = "Válassz 1 és 5 csillag között.";
            return;
        }

        ratingSubmitting = true;
        ratingErrorMessage = null;
        ratingSuccessMessage = null;

        try
        {
            if (currentUserRating == null)
            {
                var newRating = new Ratings
                    {
                        recipe_id = id,
                        user_id = currentUserId.Value,
                        ratings_value = selectedRating,
                        created_at = DateTime.Now
                    };

                var response = await Http.PostAsJsonAsync("/api/Rating", newRating);

                if (!response.IsSuccessStatusCode)
                {
                    ratingErrorMessage = "Mentési hiba.";
                    return;
                }

                ratingSuccessMessage = "Értékelés mentve.";
            }
            else
            {
                currentUserRating.ratings_value = selectedRating;

                var response = await Http.PutAsJsonAsync(
                    $"/api/Rating/{currentUserRating.rating_id}",
                    currentUserRating);

                if (!response.IsSuccessStatusCode)
                {
                    ratingErrorMessage = "Módosítási hiba.";
                    return;
                }

                ratingSuccessMessage = "Értékelés frissítve.";
            }

            await LoadCurrentUserRating();
            await LoadRating();
        }
        finally
        {
            ratingSubmitting = false;
        }
    }
}