@page "/recipeedit/{id:int}"

@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using SharedModels = ReceptekLibrary.MODELL

@inject HttpClient Http
@inject NavigationManager Navigation

@rendermode InteractiveServer

<PageTitle>Recept szerkesztése</PageTitle>


@if (isLoading)
{
    <p>Betöltés...</p>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">

            <EditForm Model="model" OnValidSubmit="UpdateRecipe">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Cím</label>
                    <InputText class="form-control" @bind-Value="model.Title" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Leírás</label>
                    <InputTextArea class="form-control" rows="6" @bind-Value="model.Description" />
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Előkészítési idő</label>
                        <InputNumber class="form-control" @bind-Value="model.PrepTimeMin" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Főzési idő</label>
                        <InputNumber class="form-control" @bind-Value="model.CookTimeMin" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Adag</label>
                        <InputNumber class="form-control" @bind-Value="model.Servings" />
                    </div>
                </div>

                <hr />

                <h5>Tagek</h5>

                @if (!string.IsNullOrWhiteSpace(tagsMessage))
                {
                    <p>@tagsMessage</p>
                }

                @if (tagsByCategory.Count == 0)
                {
                    <p>Nincsenek elérhető tagek.</p>
                }
                else
                {
                    @foreach (var category in tagsByCategory.OrderBy(c => c.Key))
                    {
                        var isCollapsed = IsCategoryCollapsed(category.Key);

                        <div class="mb-3 border rounded">
                            <button type="button"
                                    class="btn w-100 text-start fw-bold"
                                    @onclick="() => ToggleCategory(category.Key)">
                                @(isCollapsed ? "►" : "▼") @category.Key
                            </button>

                            @if (!isCollapsed)
                            {
                                <div class="p-3 pt-2">
                                    @foreach (var tagName in category.Value.OrderBy(t => t))
                                    {
                                        if (!tagNameToId.ContainsKey(tagName))
                                        {
                                            continue;
                                        }

                                        var tagId = tagNameToId[tagName];

                                        <div class="form-check">
                                            <input type="checkbox"
                                                   class="form-check-input"
                                                   id="tag_@tagId"
                                                   checked="@selectedTagIds.Contains(tagId)"
                                                   @onclick="() => ToggleTag(tagId)" />

                                            <label class="form-check-label" for="tag_@tagId">
                                                @tagName
                                            </label>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert alert-info mt-3">@message</div>
                }

                <button type="submit"
                        class="btn btn-success mt-3"
                        disabled="@isSaving">
                    @(isSaving ? "Mentés..." : "Mentés")
                </button>

                <a class="btn btn-secondary ms-2 mt-3" href="/profile">
                    Mégse
                </a>

            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public int id { get; set; }

    private bool isLoading = true;
    private bool isSaving = false;

    private string message = string.Empty;
    private string tagsMessage = string.Empty;

    private RecipeEditModel model = new();

    private List<SharedModels.Tags> allTags = new();
    private Dictionary<string, string[]> tagsByCategory = new();
    private Dictionary<string, int> tagNameToId = new();

    private HashSet<int> selectedTagIds = new();
    private HashSet<string> collapsedCategories = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadTags();
        await LoadRecipe();
        isLoading = false;
    }

    private async Task LoadTags()
    {
        try
        {
            allTags = await Http.GetFromJsonAsync<List<SharedModels.Tags>>("api/tags/all")
                      ?? new List<SharedModels.Tags>();

            tagsByCategory = await Http.GetFromJsonAsync<Dictionary<string, string[]>>("api/tags/byCategories")
                               ?? new Dictionary<string, string[]>();

            tagNameToId = allTags
                .GroupBy(t => t.tag_name)
                .ToDictionary(g => g.Key, g => g.First().tag_id);
        }
        catch (Exception ex)
        {
            tagsMessage = $"A tagek betöltése sikertelen: {ex.Message}";
        }
    }

    private async Task LoadRecipe()
    {
        try
        {
            var recipe = await Http.GetFromJsonAsync<SharedModels.Recipes>($"api/recipe/Recipes/{id}");

            if (recipe != null)
            {
                model.Title = recipe.title;
                model.Description = recipe.description;
                model.PrepTimeMin = recipe.prep_time_min;
                model.CookTimeMin = recipe.cook_time_min;
                model.Servings = recipe.servings;
            }

            var recipeTags = await Http.GetFromJsonAsync<List<SharedModels.Tags>>($"api/tags/byRecipe/{id}")
                             ?? new List<SharedModels.Tags>();

            selectedTagIds = recipeTags
                .Select(t => t.tag_id)
                .ToHashSet();
        }
        catch (Exception ex)
        {
            message = $"A recept betöltése sikertelen: {ex.Message}";
        }
    }

    private void ToggleTag(int tagId)
    {
        if (selectedTagIds.Contains(tagId))
        {
            selectedTagIds.Remove(tagId);
        }
        else
        {
            selectedTagIds.Add(tagId);
        }
    }

    private void ToggleCategory(string categoryName)
    {
        if (collapsedCategories.Contains(categoryName))
        {
            collapsedCategories.Remove(categoryName);
        }
        else
        {
            collapsedCategories.Add(categoryName);
        }
    }

    private bool IsCategoryCollapsed(string categoryName)
    {
        return collapsedCategories.Contains(categoryName);
    }

    private async Task UpdateRecipe()
    {
        if (isSaving) return;

        isSaving = true;
        message = string.Empty;

        try
        {
            var updatedRecipe = new SharedModels.Recipes
                {
                    recipe_id = id,
                    title = model.Title,
                    description = model.Description,
                    prep_time_min = model.PrepTimeMin,
                    cook_time_min = model.CookTimeMin,
                    servings = model.Servings
                };

            var response = await Http.PutAsJsonAsync($"api/recipe/Recipes/{id}", updatedRecipe);

            if (!response.IsSuccessStatusCode)
            {
                message = "A recept mentése sikertelen.";
                return;
            }

            var tagsResponse = await Http.PutAsJsonAsync($"api/recipe/{id}/tags", selectedTagIds.ToList());

            if (!tagsResponse.IsSuccessStatusCode)
            {
                message = "A tagek mentése sikertelen.";
                return;
            }

            Navigation.NavigateTo("/profile", forceLoad: true);
        }
        catch (Exception ex)
        {
            message = $"Hiba történt: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private class RecipeEditModel
    {
        [Required(ErrorMessage = "A cím kötelező.")]
        public string Title { get; set; } = string.Empty;

        [Required(ErrorMessage = "A leírás kötelező.")]
        public string Description { get; set; } = string.Empty;

        public int PrepTimeMin { get; set; }
        public int CookTimeMin { get; set; }
        public int Servings { get; set; } = 1;
    }
}