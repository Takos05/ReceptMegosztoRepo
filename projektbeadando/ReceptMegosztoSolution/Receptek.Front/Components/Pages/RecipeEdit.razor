@page "/recipeedit/{id:int}"
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using SharedModels = ReceptekLibrary.MODELL
@inject HttpClient Http
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Recept szerkesztése</PageTitle>

<h3>Recept szerkesztése</h3>

@if (isLoading)
{
    <p>Betöltés...</p>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">

            <EditForm Model="model" OnValidSubmit="UpdateRecipe">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Cím</label>
                    <InputText class="form-control" @bind-Value="model.Title" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Leírás</label>
                    <InputTextArea class="form-control" rows="6" @bind-Value="model.Description" />
                </div>

                <div class="row">

                    <div class="col-md-4 mb-3">
                        <label>Előkészítési idő</label>
                        <InputNumber class="form-control" @bind-Value="model.PrepTimeMin" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Főzési idő</label>
                        <InputNumber class="form-control" @bind-Value="model.CookTimeMin" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Adag</label>
                        <InputNumber class="form-control" @bind-Value="model.Servings" />
                    </div>

                </div>

                <hr />

                <h5>Tagek</h5>

<div style="background:white; color:black; padding:15px; border-radius:6px; max-height:400px; overflow:auto;">

@foreach (var category in allTags.GroupBy(t => t.category))
{
    <div class="mb-3">

        <b style="color:black;">Kategória @category.Key</b>

        @foreach (var tag in category)
        {
            <div class="form-check">

                <input type="checkbox"
                       class="form-check-input"
                       checked="@tag_ids.Contains(tag.tag_id)"
                       @onchange="() => ToggleTag(tag.tag_id)" />

                <label class="form-check-label" style="color:black; font-weight:500;">
                    @tag.name
                </label>

            </div>
        }

    </div>
}

</div>

                <button class="btn btn-success mt-3" disabled="@isSaving">
                    Mentés
                </button>

                <a class="btn btn-secondary ms-2 mt-3" href="/profile">
                    Mégse
                </a>

            </EditForm>

        </div>
    </div>
}

@code {

    [Parameter]
    public int id { get; set; }

    private bool isLoading = true;
    private bool isSaving = false;

    private RecipeEditModel model = new();

    private List<Tag> allTags = new();
    private List<int> tag_ids = new();

    private HashSet<string> collapsedCategories = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAllTags();
        await LoadRecipe();
        isLoading = false;
    }

    private async Task LoadAllTags()
    {
        allTags = await Http.GetFromJsonAsync<List<Tag>>("api/tags/all");
    }

    private async Task LoadRecipe()
    {
        var recipe = await Http.GetFromJsonAsync<SharedModels.Recipes>($"api/Recipe/Recipes/{id}");

        if (recipe != null)
        {
            model.Title = recipe.title;
            model.Description = recipe.description;
            model.PrepTimeMin = recipe.prep_time_min;
            model.CookTimeMin = recipe.cook_time_min;
            model.Servings = recipe.servings;
        }

        var recipeTags = await Http.GetFromJsonAsync<List<int>>($"api/Recipe/{id}/tags");

        if (recipeTags != null)
        {
            tag_ids = recipeTags;
        }
    }

    private void ToggleTag(int tagId)
    {
        if (tag_ids.Contains(tagId))
        {
            tag_ids.Remove(tagId);
        }
        else
        {
            tag_ids.Add(tagId);
        }
    }

    private void ToggleCategory(string categoryName)
    {
        if (collapsedCategories.Contains(categoryName))
        {
            collapsedCategories.Remove(categoryName);
        }
        else
        {
            collapsedCategories.Add(categoryName);
        }
    }

    private bool IsCategoryCollapsed(string categoryName)
    {
        return collapsedCategories.Contains(categoryName);
    }

    private async Task UpdateRecipe()
    {
        isSaving = true;

        var updatedRecipe = new SharedModels.Recipes
        {
            recipe_id = id,
            title = model.Title,
            description = model.Description,
            prep_time_min = model.PrepTimeMin,
            cook_time_min = model.CookTimeMin,
            servings = model.Servings
        };

        var response = await Http.PutAsJsonAsync($"api/Recipe/Recipes/{id}", updatedRecipe);

        if (response.IsSuccessStatusCode)
        {
            await Http.PutAsJsonAsync($"api/Recipe/{id}/tags", tag_ids);
            Navigation.NavigateTo($"/receptek/{id}");
        }

        isSaving = false;
    }

    private class RecipeEditModel
    {

        [Required]
        public string Title { get; set; } = "";

        [Required]
        public string Description { get; set; } = "";

        public int PrepTimeMin { get; set; }

        public int CookTimeMin { get; set; }

        public int Servings { get; set; }

    }

    private class Tag
    {
        public int tag_id { get; set; }
        public string name { get; set; } = "";
        public string category { get; set; } = "";
    }

}