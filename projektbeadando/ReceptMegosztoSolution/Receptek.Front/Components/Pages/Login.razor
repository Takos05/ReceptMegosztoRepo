@page "/login"
@inject HttpClient Http
@inject NavigationManager Navigation
@rendermode InteractiveServer

<h3>Bejelentkezés</h3>

<input @bind="username" placeholder="Felhasználónév" />
<input @bind="password" type="password" placeholder="Jelszó" />

<button @onclick="LoginUser" disabled="@isBusy">Login</button>

<p>@message</p>

@code {
    string username = "";
    string password = "";
    string message = "";
    bool isBusy = false;

    async Task LoginUser()
    {
        if (isBusy) return;
        isBusy = true;
        message = "";

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", new
            {
                username = username,
                password = password
            });

            if (response.IsSuccessStatusCode)
            {
                message = "Sikeres login!";
                // navigate or update UI as needed
                Navigation.NavigateTo("/");
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                message = string.IsNullOrWhiteSpace(err) ? "Hibás adatok" : err;
            }
        }
        finally
        {
            isBusy = false;
        }
    }
}