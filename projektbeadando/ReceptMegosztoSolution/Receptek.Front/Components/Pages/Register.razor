@page "/register"
@using System.ComponentModel.DataAnnotations
@inject HttpClient Http
@inject NavigationManager Navigation
@rendermode InteractiveServer

<h3>Regisztráció</h3>

<EditForm Model="@model" OnValidSubmit="@RegisterUser">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div>
        <input @bind="model.Username" placeholder="Felhasználónév" />
    </div>
    <div>
        <input @bind="model.Email" placeholder="Email" />
    </div>
    <div>
        <input @bind="model.Password" type="password" placeholder="Jelszó" />
    </div>

    <button type="submit" disabled="@isBusy">Register</button>
</EditForm>

<p>@message</p>

@code {
    class RegisterModel
    {
        [Required(ErrorMessage = "A felhasználónév megadása kötelező.")]
        public string Username { get; set; } = "";

        [Required(ErrorMessage = "Az email megadása kötelező.")]
        [EmailAddress(ErrorMessage = "Érvényes email címet adjon meg.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "A jelszó megadása kötelező.")]
        public string Password { get; set; } = "";
    }

    RegisterModel model = new();
    string message = "";
    bool isBusy = false;

    async Task RegisterUser()
    {
        if (isBusy) return;
        isBusy = true;
        message = "";

        try
        {
            // Post the full Users-like payload to the API so the server can store it in the DB
            var payload = new
            {
                username = model.Username,
                email = model.Email,
                password = model.Password
            };

            var response = await Http.PostAsJsonAsync("api/auth/register", payload);

            if (response.IsSuccessStatusCode)
            {
                message = "Sikeres regisztráció!";
                Navigation.NavigateTo("/login");
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                message = string.IsNullOrWhiteSpace(err) ? "Hiba történt" : err;
            }
        }
        finally
        {
            isBusy = false;
        }
    }
}