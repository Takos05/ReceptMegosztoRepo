@page "/register"
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using global::Receptek.Front.MODEL
@inject HttpClient Http
@inject NavigationManager Navigation
@rendermode InteractiveServer

<h3>Regisztráció</h3>

<EditForm Model="model" OnValidSubmit="RegisterUser" FormName="registerForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div>
        <label>Felhasználónév:</label><br />
        <InputText @bind-Value="model.Username" />
    </div>

    <div>
        <label>Email:</label><br />
        <InputText @bind-Value="model.Email" />
    </div>

    <div>
        <label>Jelszó:</label><br />
        <InputText @bind-Value="model.Password" type="password" />
    </div>

    <button type="submit" disabled="@isBusy">
        @(isBusy ? "Folyamatban..." : "Regisztráció")
    </button>
</EditForm>

@if (!string.IsNullOrWhiteSpace(message))
{
    <p>@message</p>
}

@code {
    private RegisterModel model = new();
    private string message = "";
    private bool isBusy = false;

    

    private async Task RegisterUser()
    {
        if (isBusy) return;

        isBusy = true;
        message = "";

        try
        {
            var payload = new
            {
                username = model.Username,
                email = model.Email,
                password = model.Password
            };
            var url = "api/auth/register";
            message = $"Hívott cím: {Http.BaseAddress}{url}";
            var response = await Http.PostAsJsonAsync("api/auth/register", payload);

            if (response.IsSuccessStatusCode)
            {
                //message = "Sikeres regisztráció!"; Nincs értelme, mert ha sikeres, akkor átirányítunk a login oldalra azonnal, teht nem látszik ez az üzenet.
                model = new RegisterModel();
                Navigation.NavigateTo("/login");
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                message = string.IsNullOrWhiteSpace(err)
                    ? $"Hiba történt. Státuszkód: {(int)response.StatusCode}"
                    : err;
            }
        }
        catch (Exception ex)
        {
            message = $"Kivétel történt: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }
}